{
  "$schema": "https://cdn.agentclientprotocol.com/registry/v1/latest/agent.schema.json",
  "id": "glue",
  "name": "Glue",
  "version": "0.6.0",
  "description": "The coding agent that holds it all together.",
  "repository": "https://github.com/HelgeSverre/glue",
  "website": "https://getglue.dev/docs/advanced/acp-server",
  "authors": ["Helge Sverre"],
  "license": "Apache-2.0",
  "distribution": {
    "binary": {
      "darwin-aarch64": {
        "archive": "https://github.com/HelgeSverre/glue/releases/download/v0.6.0/glue-macos-arm64",
        "cmd": "./glue-macos-arm64",
        "args": ["acp", "--stdio"]
      },
      "linux-aarch64": {
        "archive": "https://github.com/HelgeSverre/glue/releases/download/v0.6.0/glue-linux-arm64",
        "cmd": "./glue-linux-arm64",
        "args": ["acp", "--stdio"]
      },
      "linux-x86_64": {
        "archive": "https://github.com/HelgeSverre/glue/releases/download/v0.6.0/glue-linux-x64",
        "cmd": "./glue-linux-x64",
        "args": ["acp", "--stdio"]
      },
      "windows-x86_64": {
        "archive": "https://github.com/HelgeSverre/glue/releases/download/v0.6.0/glue-windows-x64.exe",
        "cmd": "glue-windows-x64.exe",
        "args": ["acp", "--stdio"]
      }
    }
  }
}
