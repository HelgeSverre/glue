set dotenv-load

default:
    @just --list

# Get dependencies
deps:
    dart pub get

# Regenerate committed dart_mappable outputs (.mapper.dart)
gen: deps
    dart run build_runner build

# Check that committed dart_mappable outputs are up to date.
gen-check: deps
    #!/usr/bin/env bash
    set -euo pipefail
    dart run build_runner build >/dev/null
    status="$(git status --short --untracked-files=all -- lib | grep '\.mapper\.dart$' || true)"
    if [ -n "$status" ]; then
      echo 'ERROR: .mapper.dart files are out of date — run `just gen` and commit the results.'
      echo "$status"
      exit 1
    fi

# Static analysis
analyze: deps
    dart analyze --fatal-infos

# Format all Dart files
format:
    dart format .

# Run unit tests. No-op when `test/` is absent — strategies has no
# package-local tests yet; provider coverage lives in cli/test/.
test *args:
    @if [ -d test ]; then dart test {{args}}; else echo "glue_strategies: no test/ directory, skipping."; fi

# Quality gate: gen-check + analyze + test
check: gen-check analyze test

# Cleanup
clean:
    rm -rf .dart_tool
