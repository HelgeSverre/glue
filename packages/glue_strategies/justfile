set dotenv-load

default:
    @just --list

# Get dependencies
deps:
    dart pub get

# Static analysis
analyze:
    dart analyze --fatal-infos

# Format all Dart files
format:
    dart format .

# Run unit tests. No-op when `test/` is absent — strategies has no
# package-local tests yet; provider coverage lives in cli/test/.
test *args:
    @if [ -d test ]; then dart test {{args}}; else echo "glue_strategies: no test/ directory, skipping."; fi

# Quality gate: analyze + test
check: analyze test

# Cleanup
clean:
    rm -rf .dart_tool
