set dotenv-load

default:
    @just --list

# Compile AOT native binary (injects build timestamp + git SHA via -D defines)
build:
    #!/usr/bin/env bash
    set -euo pipefail
    BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    GIT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo unknown)
    if git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null; then
      GIT_DIRTY=""
    else
      GIT_DIRTY="+dirty"
    fi
    BUILT_BY="${USER:-unknown}@$(hostname -s 2>/dev/null || echo unknown)"
    dart compile exe bin/glue.dart -o glue \
      --define=GLUE_BUILD_TIME="$BUILD_TIME" \
      --define=GLUE_GIT_SHA="$GIT_SHA" \
      --define=GLUE_GIT_DIRTY="$GIT_DIRTY" \
      --define=GLUE_BUILT_BY="$BUILT_BY"

# Compile and symlink to ~/.local/bin
install: build
    mkdir -p ~/.local/bin
    ln -sf "$(pwd)/glue" ~/.local/bin/glue

# Build and run interactively
run *args: build
    ./glue {{args}}

# Run unit tests (pass args: just test test/llm/)
test *args:
    dart test {{args}}

# Run e2e integration tests (requires: ollama + qwen2.5:7b)
e2e:
    dart test --run-skipped -t e2e

# Run network-backed integration tests (e.g. live DuckDuckGo search)
integration *args:
    dart test --run-skipped -t integration {{args}}

# Generate HTML test coverage report and open it in the browser
coverage:
    #!/usr/bin/env bash
    set -euo pipefail
    if ! command -v genhtml >/dev/null 2>&1; then
      echo "genhtml not found. Install with: brew install lcov" >&2
      exit 1
    fi
    if ! dart pub global list 2>/dev/null | grep -q '^coverage '; then
      echo "Activating coverage package..."
      dart pub global activate coverage >/dev/null
    fi
    rm -rf coverage
    dart pub global run coverage:test_with_coverage
    genhtml coverage/lcov.info -o coverage/html --quiet
    echo "Coverage report: coverage/html/index.html"
    open coverage/html/index.html

# Static analysis + layering lint
analyze:
    #!/usr/bin/env bash
    set -euo pipefail
    dart analyze --fatal-infos
    leaks=$(grep -rE "package:glue/src/(catalog|providers|skills|session|commands|shell|agent|llm|storage|config)/" lib/src/ui/ 2>/dev/null || true)
    if [ -n "$leaks" ]; then
      echo "ui/ layering violation — ui/** must not import from feature modules:" >&2
      echo "$leaks" >&2
      exit 1
    fi

# Format all Dart files
format:
    dart format .

# Regenerate bundled catalog + version constant from their source files
gen:
    dart run tool/gen_models.dart
    dart run tool/gen_version.dart

# Fail if any generated file is out of date
gen-check:
    dart run tool/gen_models.dart --check
    dart run tool/gen_version.dart --check

# Regenerate OTLP protobuf bindings used by the observability exporter
proto-gen:
    #!/usr/bin/env bash
    set -euo pipefail
    export PATH="$HOME/.pub-cache/bin:$PATH"
    if ! command -v protoc >/dev/null 2>&1; then
      echo "protoc not found. Install with: brew install protobuf" >&2
      exit 1
    fi
    if ! command -v protoc-gen-dart >/dev/null 2>&1; then
      echo "protoc-gen-dart not found. Installing via dart pub global activate protoc_plugin..."
      dart pub global activate protoc_plugin >/dev/null
    fi
    mkdir -p lib/src/generated
    protoc --proto_path=tool/proto --dart_out=lib/src/generated \
      tool/proto/opentelemetry/proto/common/v1/common.proto \
      tool/proto/opentelemetry/proto/resource/v1/resource.proto \
      tool/proto/opentelemetry/proto/trace/v1/trace.proto \
      tool/proto/opentelemetry/proto/collector/trace/v1/trace_service.proto

# Analyze + test + codegen freshness
check: gen-check analyze test

# Get dependencies
deps:
    dart pub get

# Generate API docs (→ doc/api)
docs:
    dart doc --output doc/api --validate-links

# Generate and serve API docs
docs-serve: docs
    npx serve doc/api

# Bump version, commit, tag, then build so the binary carries the tagged SHA
[confirm: "Release a new version?"]
release version:
    #!/usr/bin/env bash
    set -euo pipefail
    sed -i '' "s/^version: .*/version: {{version}}/" pubspec.yaml
    dart run tool/gen_version.dart
    echo "Updated pubspec.yaml to {{version}}"
    git add pubspec.yaml lib/src/config/version_generated.dart
    git commit -m "release: v{{version}}"
    git tag "v{{version}}"
    just build
    echo ""
    echo "Released v{{version}} — ./glue --version"
    ./glue --version
    echo "  Run: git push && git push --tags"

# Generate per-subsystem class diagrams into diagrams/ (format: svg|png|txt)
diagrams format="svg":
    #!/usr/bin/env bash
    set -euo pipefail
    if ! dart pub global list 2>/dev/null | grep -q '^dcdg '; then
      echo "dcdg not installed. Run: dart pub global activate dcdg" >&2
      exit 1
    fi
    if ! command -v plantuml >/dev/null 2>&1; then
      echo "plantuml not found. Install with: brew install plantuml" >&2
      exit 1
    fi
    # ELK layout produces much denser, more readable class diagrams than the default
    # dot layout. It needs elk-full.jar placed next to plantuml.jar — download once
    # from http://beta.plantuml.net/elk-full.jar.
    plantuml_libexec=$(dirname "$(readlink -f "$(command -v plantuml)" 2>/dev/null || greadlink -f "$(command -v plantuml)" 2>/dev/null || echo "")" 2>/dev/null || true)
    if [ -z "$plantuml_libexec" ] || [ ! -f "$plantuml_libexec/plantuml.jar" ]; then
      plantuml_libexec=$(brew --prefix plantuml 2>/dev/null)/libexec
    fi
    if [ -f "$plantuml_libexec/plantuml.jar" ] && [ ! -f "$plantuml_libexec/elk-full.jar" ]; then
      echo "Note: ELK layout jar not found — falling back to dot layout."
      echo "      Install once: curl -L -o '$plantuml_libexec/elk-full.jar' http://beta.plantuml.net/elk-full.jar"
      LAYOUT=""
    else
      LAYOUT="!pragma layout elk"
    fi
    inject_header() {
      local file=$1
      local tmp=$(mktemp)
      {
        echo "@startuml"
        echo "set namespaceSeparator ::"
        [ -n "$LAYOUT" ] && echo "$LAYOUT"
        echo "hide empty members"
        echo "hide circle"
        echo "skinparam classAttributeIconSize 0"
        tail -n +3 "$file"
      } > "$tmp"
      mv "$tmp" "$file"
    }
    mkdir -p diagrams
    subsystems=(agent app catalog commands config core credentials doctor input llm observability orchestrator providers rendering session share shell skills storage terminal tools ui web)
    echo "→ all (full project)"
    dart pub global run dcdg -b plantuml --exclude-private=all -o diagrams/_all.puml
    inject_header diagrams/_all.puml
    plantuml -t{{format}} diagrams/_all.puml
    for sub in "${subsystems[@]}"; do
      dir="lib/src/$sub"
      [ -d "$dir" ] || continue
      echo "→ $sub"
      dart pub global run dcdg -b plantuml --exclude-private=all -s "$dir" -o "diagrams/$sub.puml"
      inject_header "diagrams/$sub.puml"
      plantuml -t{{format}} "diagrams/$sub.puml"
    done
    echo ""
    echo "Generated $(ls diagrams/*.{{format}} 2>/dev/null | wc -l | tr -d ' ') diagrams in diagrams/"

# Remove build artifacts
clean:
    rm -f glue
    rm -rf doc/api
    rm -rf diagrams

# Run with DevTools observability (JIT mode, dev only)
dev *ARGS:
    dart --enable-vm-service --timeline-streams=Dart run bin/glue.dart {{ARGS}}

# Run with DevTools, paused at start for debugger attachment
dev-pause *ARGS:
    dart --enable-vm-service --pause-isolates-on-start --timeline-streams=Dart run bin/glue.dart {{ARGS}}

# Run with full profiling streams (VM, Isolate, GC, Dart)
dev-profile *ARGS:
    @echo "Starting Glue with full profiling..."
    dart --enable-vm-service --timeline-streams=VM,Isolate,GC,Dart run bin/glue.dart {{ARGS}}
