set dotenv-load

default:
    @just --list

# Compile AOT native binary to <repo>/dist/glue
build: gen
    #!/usr/bin/env bash
    set -euo pipefail
    rm -rf ../dist
    dart build cli bin/glue.dart -o ../dist
    mv ../dist/bundle/bin/glue ../dist/glue
    rm -rf ../dist/bundle

# Compile and symlink to ~/.local/bin
install: build
    mkdir -p ~/.local/bin
    ln -sf "$(cd .. && pwd)/dist/glue" ~/.local/bin/glue

# Build and run interactively
run *args: build
    @../dist/glue {{args}}

# Run unit tests (pass args: just test test/llm/)
test *args: gen
    dart test {{args}}

# Run e2e integration tests (requires: ollama + qwen3:1.7b)
e2e:
    dart test --run-skipped -t e2e

# Run network-backed integration tests (e.g. live DuckDuckGo search)
integration *args:
    dart test --run-skipped -t integration {{args}}

# Static analysis
analyze: deps
    dart analyze --fatal-infos

# Format all Dart files
format:
    dart format .

# Regenerate bundled catalog + version constant from their source files
gen: deps
    dart run tool/gen_models.dart
    dart run tool/gen_version.dart
    dart run tool/gen_build_info.dart
    dart run tool/gen_share_assets.dart

# Fail if any generated file is out of date
gen-check:
    dart run tool/gen_models.dart --check
    dart run tool/gen_version.dart --check
    dart run tool/gen_share_assets.dart --check

# Layer-import linter (strict — see docs/plans/2026-04-29-harness-layers.md)
# Enforces the full four-layer architecture: surface → harness → strategies → core.
check-layers *args:
    dart run tool/check_layers.dart --strict {{args}}

# Analyze + test + codegen freshness + layer hygiene
check: gen-check analyze test check-layers

# Get dependencies
deps:
    dart pub get

# Generate API docs (→ doc/api)
docs:
    dart doc --output doc/api --validate-links

# Generate and serve API docs
docs-serve: docs
    npx serve doc/api

# Bump version, commit, tag, then build so the binary carries the tagged SHA
[confirm: "Release a new version?"]
release version:
    #!/usr/bin/env bash
    set -euo pipefail
    sed -i '' "s/^version: .*/version: {{version}}/" pubspec.yaml
    dart run tool/gen_version.dart
    echo "Updated pubspec.yaml to {{version}}"
    git add pubspec.yaml ../packages/glue_core/lib/src/version_generated.dart
    git commit -m "release: v{{version}}"
    git tag "v{{version}}"
    just build
    echo ""
    echo "Released v{{version}} — ../dist/glue --version"
    ../dist/glue --version
    echo "  Run: git push && git push --tags"

# Generate per-subsystem class diagrams into diagrams/ (format: svg|png|txt)
diagrams format="svg":
    #!/usr/bin/env bash
    set -euo pipefail
    if ! dart pub global list 2>/dev/null | grep -q '^dcdg '; then
      echo "dcdg not installed. Run: dart pub global activate dcdg" >&2
      exit 1
    fi
    if ! command -v plantuml >/dev/null 2>&1; then
      echo "plantuml not found. Install with: brew install plantuml" >&2
      exit 1
    fi
    mkdir -p diagrams
    subsystems=(agent app catalog commands config core credentials doctor input llm observability orchestrator providers rendering session share shell skills storage terminal tools ui web)
    echo "→ all (full project)"
    dart pub global run dcdg -b plantuml --exclude-private=all -o diagrams/_all.puml
    plantuml -t{{format}} diagrams/_all.puml
    for sub in "${subsystems[@]}"; do
      dir="lib/src/$sub"
      [ -d "$dir" ] || continue
      echo "→ $sub"
      dart pub global run dcdg -b plantuml --exclude-private=all -s "$dir" -o "diagrams/$sub.puml"
      plantuml -t{{format}} "diagrams/$sub.puml"
    done
    echo ""
    echo "Generated $(ls diagrams/*.{{format}} 2>/dev/null | wc -l | tr -d ' ') diagrams in diagrams/"

# Remove build artifacts
clean:
    rm -rf ../dist build
    rm -rf doc/api
    rm -rf diagrams

# Run with DevTools observability (JIT mode, dev only)
dev *ARGS:
    dart --enable-vm-service --timeline-streams=Dart run bin/glue.dart {{ARGS}}

# Run with DevTools, paused at start for debugger attachment
dev-pause *ARGS:
    dart --enable-vm-service --pause-isolates-on-start --timeline-streams=Dart run bin/glue.dart {{ARGS}}

# Run with full profiling streams (VM, Isolate, GC, Dart)
dev-profile *ARGS:
    @echo "Starting Glue with full profiling..."
    dart --enable-vm-service --timeline-streams=VM,Isolate,GC,Dart run bin/glue.dart {{ARGS}}
