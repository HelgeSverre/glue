default:
    @just --list

build:
    dart compile exe bin/glue.dart -o glue

install: build
    mkdir -p ~/.local/bin
    ln -sf "$(pwd)/glue" ~/.local/bin/glue

test:
    dart test

analyze:
    dart analyze --fatal-infos

format:
    dart format .

check: analyze test

clean:
    rm -f glue
    rm -rf dartdoc

docs:
    dart doc --output ./dartdoc --validate-links
    npx serve ./dartdoc/
