default:
    @just --list

up:
    cp -n .dockerconfig.example .dockerconfig || true
    docker compose --env-file .dockerconfig up -d

up-llm:
    cp -n .dockerconfig.example .dockerconfig || true
    docker compose --env-file .dockerconfig --profile llm up -d

up-extras:
    cp -n .dockerconfig.example .dockerconfig || true
    docker compose --env-file .dockerconfig --profile extras up -d

up-tool tool:
    cp -n .dockerconfig.example .dockerconfig || true
    docker compose --env-file .dockerconfig --profile tool-{{tool}} up -d

down:
    docker compose --env-file .dockerconfig down

logs *services:
    docker compose --env-file .dockerconfig logs -f {{services}}

ps:
    docker compose --env-file .dockerconfig ps

config:
    docker compose --env-file .dockerconfig config
