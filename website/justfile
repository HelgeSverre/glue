default:
    @just --list

# Install JavaScript dependencies
deps:
    npm ci

[private]
deps-if-needed:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -d node_modules ]; then
        npm ci
    fi

# Generate API docs from Dart source
generate:
    cd ../cli && dart run tool/generate_website_api.dart
    cd ../cli && dart run tool/generate_site_reference.dart

# Regenerate site reference files only (models, runtime matrix, config, sessions)
generate-reference:
    cd ../cli && dart run tool/generate_site_reference.dart

# Fail if generated reference files are out of date with canonical sources
check-generated: generate-reference
    #!/usr/bin/env bash
    set -euo pipefail
    if ! git diff --quiet -- generated/; then
      echo "✗ Generated site reference files are out of date." >&2
      echo "  Run 'just website::generate-reference' and commit the result." >&2
      git --no-pager diff --stat -- generated/ >&2
      exit 1
    fi
    echo "✓ Generated site reference files match canonical sources."

# Serve locally for development
dev: deps-if-needed generate
    npx vitepress dev

# Build static site
build: deps-if-needed generate
    npx vitepress build

# Quality gate for docs (drift check + consistency check + build)
check: check-generated check-consistency build

# Consistency checks — feature-status labels, banned terms, install-snippet uniqueness
check-consistency:
    cd ../cli && dart run tool/check_site_consistency.dart

# Preview production build
preview: deps-if-needed build
    npx vitepress preview

# Remove docs build artifacts
clean:
    rm -rf .vitepress/dist .vitepress/cache
